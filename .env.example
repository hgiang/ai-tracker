# Database
DATABASE_URL=sqlite+aiosqlite:///./ai_tracker.db

# GitHub Personal Access Token (optional, raises rate limit)
GITHUB_TOKEN=

# X/Twitter Bearer Token (https://developer.x.com)
X_BEARER_TOKEN=

# Data retention (days)
RETENTION_DAYS=180

# Relevance keywords (comma-separated)
RELEVANCE_KEYWORDS=llm,large language model,gpt,claude,gemini,deep learning,transformer,agentic,ai agent,rag,fine-tuning,diffusion,multimodal

# Kimi K2.5 LLM API (for paper summary and notebook generation)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# Digest LLM re-ranking — leave provider empty to disable and use heuristic order only.
# Reads preferences.md as the filter context.
DIGEST_LLM_PROVIDER=
DIGEST_LLM_API_KEY=
DIGEST_CANDIDATE_POOL_SIZE=40
DIGEST_TARGET_SIZE=20
PREFERENCES_PATH=preferences.md
